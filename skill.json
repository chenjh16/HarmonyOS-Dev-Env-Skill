{
  "name": "harmonyos-dev-env",
  "version": "1.0.0",
  "description": "HarmonyOS PC development environment skill - complete build and installation guides for Python, Rust, Go, PyTorch, llama.cpp and more",
  "description_cn": "HarmonyOS PC 开发环境技能包 - Python、Rust、Go、PyTorch、llama.cpp 等工具的完整构建和安装指南",
  "author": "chenjh16",
  "repository": "https://github.com/chenjh16/HarmonyOS-Dev-Env-Skill",
  "platform": {
    "name": "HarmonyOS",
    "kernel": "HongMeng Kernel 1.12.0",
    "arch": "aarch64",
    "libc": "musl",
    "compiler": "clang 15.0.4"
  },
  "tools": [
    {
      "name": "python",
      "version": "3.12.8",
      "category": "language",
      "source": "https://www.python.org/ftp/python/3.12.8/Python-3.12.8.tar.xz",
      "build_guide": "tools/python/build.md",
      "install_script": "tools/python/install.sh",
      "install_dir": "$HOME/.local",
      "features": ["pip", "extension modules", "numpy", "pillow", "lxml"]
    },
    {
      "name": "rust",
      "version": "1.95.0",
      "category": "language",
      "source": "https://static.rust-lang.org/dist/",
      "build_guide": "tools/rust/build.md",
      "install_script": "tools/rust/install.sh",
      "install_dir": "$HOME/.rust",
      "features": ["rustc", "cargo", "FFI", "official ohos target"]
    },
    {
      "name": "go",
      "version": "1.22.5",
      "category": "language",
      "source": "https://go.dev/dl/go1.22.5.linux-arm64.tar.gz",
      "build_guide": "tools/go/build.md",
      "install_script": "tools/go/install.sh",
      "install_dir": "$HOME/Claude/go-build/go",
      "features": ["go", "gofmt", "GOPROXY support"]
    },
    {
      "name": "pytorch",
      "version": "2.5.1",
      "category": "ml-framework",
      "source": "https://github.com/pytorch/pytorch (v2.5.1)",
      "build_guide": "tools/pytorch/build.md",
      "install_script": "tools/pytorch/install.sh",
      "install_dir": "$HOME/.local/lib/python3.12/site-packages/torch",
      "features": ["tensor ops", "nn modules", "autograd", "optimizers", "MNIST training"]
    },
    {
      "name": "llama-cpp",
      "version": "b9073",
      "category": "ml-inference",
      "source": "https://github.com/ggml-org/llama.cpp",
      "build_guide": "tools/llama-cpp/build.md",
      "install_script": "tools/llama-cpp/install.sh",
      "install_dir": "$HOME/Claude/llama.cpp/build/bin",
      "features": ["llama-cli", "llama-server", "NEON/SVE optimization", "Qwen3.5 support"]
    },
    {
      "name": "mihomo",
      "version": "Meta",
      "category": "network",
      "source": "https://github.com/MetaCubeX/mihomo (Meta branch)",
      "build_guide": "tools/mihomo/build.md",
      "install_script": "tools/mihomo/install.sh",
      "install_dir": "$HOME/Claude/mihomo-build/bin",
      "features": ["proxy", "HTTP/SOCKS5", "API control", "GEOIP/GEOSITE rules", "intelligent routing"]
    },
    {
      "name": "eza",
      "version": "0.23.4",
      "category": "utility",
      "source": "https://github.com/eza-community/eza",
      "build_guide": "tools/eza/build.md",
      "install_script": "tools/eza/install.sh",
      "install_dir": "$HOME/Claude/eza-build/eza/target/release",
      "features": ["modern ls", "colors", "icons", "tree view"]
    },
    {
      "name": "bat",
      "version": "0.26.1",
      "category": "utility",
      "source": "https://github.com/sharkdp/bat",
      "build_guide": "tools/bat/build.md",
      "install_script": "tools/bat/install.sh",
      "install_dir": "$HOME/Claude/bat-build/bat/target/release",
      "features": ["syntax highlighting", "cat replacement"]
    },
    {
      "name": "starship",
      "version": "1.25.1",
      "category": "utility",
      "source": "https://github.com/starship/starship",
      "build_guide": "tools/starship/build.md",
      "install_script": "tools/starship/install.sh",
      "install_dir": "$HOME/Claude/starship-build/starship/target/release",
      "features": ["cross-shell prompt", "customizable"]
    },
    {
      "name": "dropbear",
      "version": "2024.86",
      "category": "network",
      "source": "https://matt.ucc.asn.au/dropbear/releases/dropbear-2024.86.tar.bz2",
      "build_guide": "tools/dropbear/build.md",
      "install_script": "tools/dropbear/install.sh",
      "install_dir": "$HOME/.local/bin",
      "features": ["SSH server", "SSH client", "pubkey auth only", "lightweight", "auto-start on login", "5 HarmonyOS patches", "V8 crash workaround"]
    }
  ],
  "core_issues": [
    {
      "name": "code-signing",
      "description": "All ELF binaries must be signed before execution",
      "guide": "docs/code-signing.md"
    },
    {
      "name": "tmpdir",
      "description": "/tmp is read-only, use $HOME/Claude/tmpdir",
      "guide": "rules/CLAUDE.md"
    },
    {
      "name": "ld-library-path",
      "description": "/usr/lib must come first to avoid OpenSSL symbol version conflict",
      "guide": "docs/ld-library-path.md"
    },
    {
      "name": "linker-wrapper",
      "description": "SDK lld requires libxml2.so.16, use ld.bfd wrapper",
      "guide": "rules/CLAUDE.md"
    },
    {
      "name": "no-gcc",
      "description": "Only clang available, no gcc",
      "guide": "CLAUDE.md"
    },
    {
      "name": "ssh-v8-crash",
      "description": "V8 JIT crashes in SSH PTY, use --jitless + node-fetch polyfill",
      "guide": "tools/dropbear/build.md"
    }
  ],
  "documentation": [
    {"name": "Python Environment", "path": "docs/python-harmonyos.md", "path_cn": "docs/python-harmonyos.cn.md"},
    {"name": "Python Packages", "path": "docs/python-packages-harmonyos.md", "path_cn": "docs/python-packages-harmonyos.cn.md"},
    {"name": "llama.cpp", "path": "docs/llama-cpp-harmonyos.md", "path_cn": "docs/llama-cpp-harmonyos.cn.md"},
    {"name": "Rust", "path": "docs/rust-harmonyos.md", "path_cn": "docs/rust-harmonyos.cn.md"},
    {"name": "PyTorch", "path": "docs/pytorch-harmonyos.md", "path_cn": "docs/pytorch-harmonyos.cn.md"},
    {"name": "mihomo", "path": "docs/mihomo-harmonyos.md", "path_cn": "docs/mihomo-harmonyos.cn.md"},
    {"name": "eza", "path": "docs/eza-harmonyos.md", "path_cn": "docs/eza-harmonyos.cn.md"},
    {"name": "bat", "path": "docs/bat-harmonyos.md", "path_cn": "docs/bat-harmonyos.cn.md"},
    {"name": "starship", "path": "docs/starship-harmonyos.md", "path_cn": "docs/starship-harmonyos.cn.md"},
    {"name": "Dropbear SSH", "path": "docs/dropbear-harmonyos.md", "path_cn": "docs/dropbear-harmonyos.cn.md"},
    {"name": "Code Signing", "path": "docs/code-signing.md", "path_cn": "docs/code-signing.cn.md"},
    {"name": "LD_LIBRARY_PATH", "path": "docs/ld-library-path.md", "path_cn": "docs/ld-library-path.cn.md"}
  ],
  "env_config": {
    "shell_config": "config/.zshenv",
    "claude_rules": ["rules/CLAUDE.md", "rules/CLAUDE.cn.md"],
    "ssh_polyfill": "config/.claude/ssh-fetch-polyfill.js",
    "start_script": "config/.claude/start-claude.sh"
  }
}